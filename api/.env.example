# 与 docker-compose.yml 默认账号/库名/端口一致。
DATABASE_URL=postgresql://judgment:judgment@localhost:5432/judgment_forge
# 材料原文件落盘目录（相对 api/ 或绝对路径均可）；默认 api/data/materials
# MATERIALS_DIR=data/materials
# 单文件上传上限（字节），默认 10MB
# MAX_UPLOAD_BYTES=10485760

# 模型 Provider：fake（默认，测/本地）| openai_compatible（OpenAI 或 DashScope 兼容模式）
# LLM_PROVIDER=fake
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# DashScope 兼容示例：https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=gpt-4o-mini
